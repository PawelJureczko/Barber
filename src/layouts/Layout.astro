---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}

const {
  title = 'Razor Sznyt — Barber Shop Knurów | Precyzja w każdym cięciu',
  description = 'Razor Sznyt to najlepszy barber shop w Knurowie. Profesjonalne strzyżenie, stylizacja brody i fachowe doradztwo. Umów wizytę online przez Booksy.',
  image = '/images/hero.webp',
  canonicalUrl = Astro.url.href,
} = Astro.props;

const GA_ID = 'G-XXXXXXXXXX'; // TODO: replace with real GA4 Measurement ID

const siteUrl = 'https://razorsznyt.pl';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HairSalon',
  name: 'Razor Sznyt',
  description: 'Nowoczesny barber shop w Knurowie. Strzyżenie, broda, doradztwo fryzjerskie.',
  url: siteUrl,
  telephone: '+48572216680',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Batorego 4',
    addressLocality: 'Knurów',
    postalCode: '44-194',
    addressCountry: 'PL',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 50.2206,
    longitude: 18.6611,
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Monday', opens: '12:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Tuesday', opens: '10:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Wednesday', opens: '10:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Thursday', opens: '10:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Friday', opens: '10:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Saturday', opens: '09:00', closes: '17:00' },
  ],
  sameAs: [
    'https://www.instagram.com/razor_sznyt/',
    'https://www.facebook.com/p/Razor-Sznyt-61563316386455/',
    'https://booksy.com/pl-pl/253466_razor-sznyt_barber-shop_12841_knurow',
  ],
  priceRange: '$$',
  image: `${siteUrl}/images/og-image.jpg`,
};
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0d0d0d" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:site_name" content="Razor Sznyt" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/images/favicon.png`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Google Analytics 4 — Consent Mode v2 -->
    <!-- 1. Inicjalizacja dataLayer i domyślna zgoda PRZED załadowaniem gtag.js -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }

      gtag('consent', 'default', {
        analytics_storage:  'denied',
        ad_storage:         'denied',
        ad_user_data:       'denied',
        ad_personalization: 'denied',
        wait_for_update:    500,
      });
    </script>

    <!-- 2. Ładowanie skryptu GA -->
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>

    <!-- 3. Konfiguracja GA + przywrócenie zgody jeśli już udzielona -->
    <script is:inline define:vars={{ GA_ID }}>
      gtag('js', new Date());
      gtag('config', GA_ID, { send_page_view: true });

      if (localStorage.getItem('cookie-consent') === 'accepted') {
        gtag('consent', 'update', { analytics_storage: 'granted' });
      }

      window.trackCTA = function(location) {
        gtag('event', 'booksy_cta_click', {
          event_category: 'engagement',
          event_label: location,
        });
      };

      window.grantAnalyticsConsent = function() {
        gtag('consent', 'update', { analytics_storage: 'granted' });
      };
    </script>
  </head>
  <body>
    <slot />
    <CookieBanner />
  </body>
</html>
