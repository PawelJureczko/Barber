---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const BOOKSY_URL = 'https://booksy.com/pl-pl/253466_razor-sznyt_barber-shop_12841_knurow#ba_s=seo';

const hours = [
  { day: 'Poniedziałek', open: '12:00 – 20:00' },
  { day: 'Wtorek',       open: '10:00 – 20:00' },
  { day: 'Środa',        open: '10:00 – 20:00' },
  { day: 'Czwartek',     open: '10:00 – 20:00' },
  { day: 'Piątek',       open: '10:00 – 20:00' },
  { day: 'Sobota',       open: '09:00 – 17:00' },
  { day: 'Niedziela',    open: null },
];

// Get today's day index (0=Sunday, 1=Monday, ...)
// We'll handle this client-side for accuracy
---

<section id="kontakt" class="section-padding bg-brand-black">
  <div class="container mx-auto px-6 lg:px-8">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

      <!-- Left: info -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <span class="block w-8 h-px bg-brand-gold" aria-hidden="true"></span>
          <span class="text-brand-gold text-xs tracking-[0.4em] uppercase font-medium">Kontakt & Lokalizacja</span>
        </div>

        <h2 class="font-heading text-4xl sm:text-5xl font-bold leading-tight mb-10">
          Znajdź<br />
          <span class="text-gradient">nas.</span>
        </h2>

        <!-- Address -->
        <div class="flex gap-4 mb-8">
          <div class="shrink-0 w-10 h-10 flex items-center justify-center border border-brand-gold/30 text-brand-gold">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <p class="text-brand-text font-medium mb-1">Adres</p>
            <a
              href="https://maps.google.com/?q=Batorego+4,+44-194+Knurów"
              target="_blank"
              rel="noopener noreferrer"
              class="text-brand-muted hover:text-brand-gold transition-colors duration-300 text-sm"
            >
              ul. Batorego 4<br />
              44-194 Knurów
            </a>
          </div>
        </div>

        <!-- Phone -->
        <div class="flex gap-4 mb-8">
          <div class="shrink-0 w-10 h-10 flex items-center justify-center border border-brand-gold/30 text-brand-gold">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <p class="text-brand-text font-medium mb-1">Telefon</p>
            <a
              href="tel:+48572216680"
              class="text-brand-muted hover:text-brand-gold transition-colors duration-300 text-sm"
            >
              572 216 680
            </a>
          </div>
        </div>

        <!-- Hours -->
        <div class="flex gap-4">
          <div class="shrink-0 w-10 h-10 flex items-center justify-center border border-brand-gold/30 text-brand-gold">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="flex-1">
            <p class="text-brand-text font-medium mb-3">Godziny otwarcia</p>
            <ul class="space-y-2">
              {hours.map((h, i) => (
                <li
                  class="flex justify-between items-center text-sm py-1.5 border-b border-white/5 last:border-0 hours-row"
                  data-day-index={i === 6 ? 0 : i + 1}
                >
                  <span class="text-brand-muted">{h.day}</span>
                  {h.open
                    ? <span class="text-brand-text font-medium tabular-nums">{h.open}</span>
                    : <span class="text-brand-muted italic text-xs">Zamknięte</span>
                  }
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-10">
          <a
            href={BOOKSY_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 px-8 py-4 bg-brand-gold text-brand-black font-semibold tracking-widest uppercase text-sm transition-all duration-300 hover:bg-brand-gold-light hover:gap-4"
            onclick="window.trackCTA && window.trackCTA('location')"
          >
            Zarezerwuj przez Booksy
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>

          <!-- Social links -->
          <div class="flex items-center gap-5 mt-6">
            <a
              href="https://www.instagram.com/razor_sznyt/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-brand-muted hover:text-brand-gold transition-colors duration-300 text-sm tracking-wider uppercase font-medium"
              aria-label="Instagram Razor Sznyt"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
              Instagram
            </a>
            <span class="w-px h-4 bg-white/20" aria-hidden="true"></span>
            <a
              href="https://www.facebook.com/profile.php?id=61563316386455"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-brand-muted hover:text-brand-gold transition-colors duration-300 text-sm tracking-wider uppercase font-medium"
              aria-label="Facebook Razor Sznyt"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              Facebook
            </a>
          </div>
        </div>
      </div>

      <!-- Right: map image -->
      <div class="relative">
        <a
          href="https://maps.google.com/?q=Batorego+4,+44-194+Knurów"
          target="_blank"
          rel="noopener noreferrer"
          class="group block w-full h-64 sm:h-80 lg:h-full min-h-80 overflow-hidden border border-white/10 relative"
          aria-label="Otwórz lokalizację w Google Maps"
        >
          <img
            src={`${base}/images/map.png`}
            alt="Mapa — Razor Sznyt Barber Shop, ul. Batorego 4, Knurów"
            class="w-full h-full object-cover opacity-60"
            style="object-position: 36% 51%"
            loading="lazy"
            width="600"
            height="504"
          />
          <!-- Overlay on hover -->
          <div class="absolute inset-0 bg-brand-black/0 group-hover:bg-brand-black/30 transition-colors duration-300 flex items-center justify-center">
            <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-brand-gold text-brand-black text-xs font-semibold tracking-widest uppercase px-4 py-2">
              Otwórz w Mapach Google →
            </span>
          </div>
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  // Highlight today's row
  const today = new Date().getDay(); // 0=Sun, 1=Mon, ...
  document.querySelectorAll('.hours-row').forEach(row => {
    const dayIndex = parseInt((row as HTMLElement).dataset.dayIndex ?? '-1');
    if (dayIndex === today) {
      row.classList.add('text-brand-gold');
      const spans = row.querySelectorAll('span');
      spans.forEach(s => {
        s.classList.remove('text-brand-muted', 'text-brand-text');
        s.classList.add('text-brand-gold');
      });
    }
  });
</script>
