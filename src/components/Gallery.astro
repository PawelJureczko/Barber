---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const photos = [
  { src: `${base}/images/gallery-1.webp`, alt: 'Fade rude włosy — Razor Sznyt Knurów', wide: false, pos: 'center 40%' },
  { src: `${base}/images/gallery-2.webp`, alt: 'Stylizacja brody — Razor Sznyt Knurów', wide: false, pos: 'center 50%' },
  { src: `${base}/images/gallery-3.webp`, alt: 'Fade z brodą — Razor Sznyt Knurów', wide: false, pos: 'center 30%' },
  { src: `${base}/images/gallery-4.webp`, alt: 'Undercut fade — Razor Sznyt Knurów', wide: false, pos: 'center 35%' },
  { src: `${base}/images/gallery-5.webp`, alt: 'Pompadour fade — Razor Sznyt Knurów', wide: true, pos: 'center 30%' },
  { src: `${base}/images/gallery-6.webp`, alt: 'Side part fade — Razor Sznyt Knurów', wide: true, pos: 'center 35%' },
];

const BOOKSY_URL = 'https://booksy.com/pl-pl/253466_razor-sznyt_barber-shop_12841_knurow#ba_s=seo';
---

<section id="galeria" class="section-padding bg-brand-black overflow-hidden">
  <div class="container mx-auto px-6 lg:px-8">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12 lg:mb-16">
      <div>
        <div class="flex items-center gap-3 mb-6">
          <span class="block w-8 h-px bg-brand-gold" aria-hidden="true"></span>
          <span class="text-brand-gold text-xs tracking-[0.4em] uppercase font-medium">Galeria</span>
        </div>
        <h2 class="font-heading text-4xl sm:text-5xl font-bold leading-tight">
          Nasze<br />
          <span class="text-gradient">prace.</span>
        </h2>
      </div>
      <a
        href="https://www.instagram.com/razor_sznyt/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-brand-muted hover:text-brand-gold transition-colors duration-300 text-sm tracking-wider uppercase font-medium shrink-0"
        aria-label="Zobacz więcej na Instagramie"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        Instagram
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

    <!-- Infinite marquee strip -->
    <div class="relative">
      <!-- Row 1 — scrolls left -->
      <div class="gallery-overflow mb-4" id="gallery-row-1">
        <div class="gallery-track gallery-track--left flex gap-4">
          {[...photos, ...photos, ...photos, ...photos].map((photo) => (
            <div class={`gallery-item shrink-0 overflow-hidden ${photo.wide ? 'w-72 sm:w-96' : 'w-56 sm:w-72'} h-64 sm:h-80`}>
              <img
                src={photo.src}
                alt={photo.alt}
                class="w-full h-full object-cover transition-transform duration-700 hover:scale-110"
                style={`object-position: ${photo.pos}`}
                loading="lazy"
                width="400"
                height="320"
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Row 2 — scrolls right -->
      <div class="gallery-overflow" id="gallery-row-2">
        <div class="gallery-track gallery-track--right flex gap-4">
          {[...photos.slice().reverse(), ...photos.slice().reverse(), ...photos.slice().reverse(), ...photos.slice().reverse()].map((photo) => (
            <div class={`gallery-item shrink-0 overflow-hidden ${photo.wide ? 'w-72 sm:w-96' : 'w-56 sm:w-72'} h-64 sm:h-80`}>
              <img
                src={photo.src}
                alt={photo.alt}
                class="w-full h-full object-cover transition-transform duration-700 hover:scale-110"
                style={`object-position: ${photo.pos}`}
                loading="lazy"
                width="400"
                height="320"
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Gradient fade edges -->
      <div class="absolute inset-y-0 left-[-1px] w-16 sm:w-32 bg-gradient-to-r from-brand-black to-transparent pointer-events-none z-10" aria-hidden="true"></div>
      <div class="absolute inset-y-0 right-[-1px] w-16 sm:w-32 bg-gradient-to-l from-brand-black to-transparent pointer-events-none z-10" aria-hidden="true"></div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-14">
      <a
        href={BOOKSY_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-3 px-8 py-4 bg-brand-gold text-brand-black font-semibold tracking-widest uppercase text-sm transition-all duration-300 hover:bg-brand-gold-light hover:gap-4"
        onclick="window.trackCTA && window.trackCTA('gallery')"
      >
        Chcę tak samo — umawiam wizytę
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .gallery-overflow {
    overflow: hidden;
  }

  @keyframes marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes marquee-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  .gallery-track--left {
    width: max-content;
    animation: marquee-left 300s linear infinite;
  }

  .gallery-track--right {
    width: max-content;
    animation: marquee-right 300s linear infinite;
  }

  .gallery-track--left.paused,
  .gallery-track--right.paused {
    animation-play-state: paused;
  }

  .gallery-item {
    position: relative;
  }

  .gallery-item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.25);
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .gallery-item:hover::after {
    opacity: 0;
  }
</style>

<script>
  const rows = document.querySelectorAll<HTMLElement>('.gallery-overflow');
  rows.forEach(row => {
    const track = row.querySelector<HTMLElement>('.gallery-track');
    row.addEventListener('mouseenter', () => track?.classList.add('paused'));
    row.addEventListener('mouseleave', () => track?.classList.remove('paused'));
  });
</script>
