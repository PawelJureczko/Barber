---
const BOOKSY_URL = 'https://booksy.com/pl-pl/253466_razor-sznyt_barber-shop_12841_knurow#ba_s=seo';

const navLinks = [
  { href: '#o-nas', label: 'O nas' },
  { href: '#uslugi', label: 'Usługi' },
  { href: '#galeria', label: 'Galeria' },
  { href: '#team', label: 'Zespół' },
  { href: '#kontakt', label: 'Kontakt' },
];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="container mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-18 py-4">
      <!-- Logo -->
      <a href="#hero" class="flex items-center" aria-label="Razor Sznyt — strona główna">
        <img
          src="/images/logo.svg"
          alt="Razor Sznyt Barber Shop"
          class="h-12 w-auto"
          width="1280"
          height="1112"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-8" aria-label="Nawigacja główna">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-sm tracking-wider text-brand-text/70 hover:text-brand-gold transition-colors duration-300 uppercase font-medium"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA + Mobile menu button -->
      <div class="flex items-center gap-4">
        <a
          href={BOOKSY_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 bg-brand-gold text-brand-black text-sm font-semibold tracking-wider uppercase transition-all duration-300 hover:bg-brand-gold-light hover:scale-105"
          onclick="window.trackCTA && window.trackCTA('nav')"
        >
          Umów wizytę
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden flex flex-col gap-1.5 p-2 group"
          aria-label="Otwórz menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="block w-6 h-0.5 bg-brand-text transition-all duration-300 group-[.open]:rotate-45 group-[.open]:translate-y-2"></span>
          <span class="block w-6 h-0.5 bg-brand-text transition-all duration-300 group-[.open]:opacity-0"></span>
          <span class="block w-6 h-0.5 bg-brand-text transition-all duration-300 group-[.open]:-rotate-45 group-[.open]:-translate-y-2"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-white/5 bg-brand-black/95 backdrop-blur-lg"
    aria-label="Menu mobilne"
  >
    <nav class="container mx-auto px-6 py-6 flex flex-col gap-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="mobile-nav-link text-base tracking-wider text-brand-muted hover:text-brand-gold transition-colors duration-300 uppercase font-medium py-2 border-b border-white/5"
        >
          {link.label}
        </a>
      ))}
      <a
        href={BOOKSY_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 inline-flex items-center justify-center px-6 py-3 bg-brand-gold text-brand-black text-sm font-semibold tracking-wider uppercase"
        onclick="window.trackCTA && window.trackCTA('mobile-menu')"
      >
        Umów wizytę
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('header')!;
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;

  // Scroll — add background
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header.classList.add('bg-brand-black/95', 'backdrop-blur-lg', 'shadow-2xl');
    } else {
      header.classList.remove('bg-brand-black/95', 'backdrop-blur-lg', 'shadow-2xl');
    }
  }, { passive: true });

  // Mobile menu toggle
  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
    btn.classList.toggle('open', !isOpen);
  });

  // Close on nav link click
  menu.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      btn.classList.remove('open');
    });
  });
</script>
