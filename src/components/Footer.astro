---
const BOOKSY_URL = 'https://booksy.com/pl-pl/253466_razor-sznyt_barber-shop_12841_knurow#ba_s=seo';
const year = new Date().getFullYear();

const navLinks = [
  { href: '#o-nas',   label: 'O nas' },
  { href: '#uslugi',  label: 'Usługi' },
  { href: '#galeria', label: 'Galeria' },
  { href: '#team',    label: 'Zespół' },
  { href: '#kontakt', label: 'Kontakt' },
];
---

<footer class="bg-brand-surface border-t border-white/5">

  <!-- Main footer -->
  <div class="container mx-auto px-6 lg:px-8 py-14 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <p class="font-heading text-2xl font-bold tracking-widest uppercase mb-2">
          Razor<span class="text-brand-gold">.</span>Sznyt
        </p>
        <p class="text-brand-muted text-sm mb-6 leading-relaxed">
          Precyzja w każdym cięciu.<br />
          Barber Shop · Knurów
        </p>
        <!-- Social -->
        <div class="flex gap-4">
          <a
            href="https://www.instagram.com/razor_sznyt/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram Razor Sznyt"
            class="w-9 h-9 flex items-center justify-center border border-white/10 text-brand-muted hover:text-brand-gold hover:border-brand-gold transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a
            href="https://www.facebook.com/p/Razor-Sznyt-61563316386455/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook Razor Sznyt"
            class="w-9 h-9 flex items-center justify-center border border-white/10 text-brand-muted hover:text-brand-gold hover:border-brand-gold transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href={BOOKSY_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Booksy — umów wizytę w Razor Sznyt"
            class="w-9 h-9 flex items-center justify-center border border-white/10 text-brand-muted hover:text-brand-gold hover:border-brand-gold transition-all duration-300"
            onclick="window.trackCTA && window.trackCTA('footer-social')"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav -->
      <div>
        <p class="text-xs tracking-[0.3em] uppercase text-brand-muted font-medium mb-5">Menu</p>
        <ul class="space-y-3">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm text-brand-muted hover:text-brand-gold transition-colors duration-300"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-xs tracking-[0.3em] uppercase text-brand-muted font-medium mb-5">Kontakt</p>
        <ul class="space-y-3 text-sm">
          <li>
            <a
              href="tel:+48572216680"
              class="text-brand-muted hover:text-brand-gold transition-colors duration-300"
            >
              572 216 680
            </a>
          </li>
          <li>
            <a
              href="https://maps.google.com/?q=Batorego+4,+44-194+Knurów"
              target="_blank"
              rel="noopener noreferrer"
              class="text-brand-muted hover:text-brand-gold transition-colors duration-300 leading-relaxed"
            >
              ul. Batorego 4<br />44-194 Knurów
            </a>
          </li>
        </ul>
      </div>

      <!-- CTA block -->
      <div>
        <p class="text-xs tracking-[0.3em] uppercase text-brand-muted font-medium mb-5">Rezerwacja</p>
        <p class="text-brand-muted text-sm mb-5 leading-relaxed">
          Umów się online przez Booksy — szybko, bez dzwonienia.
        </p>
        <a
          href={BOOKSY_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-gold text-brand-black text-xs font-semibold tracking-widest uppercase transition-all duration-300 hover:bg-brand-gold-light"
          onclick="window.trackCTA && window.trackCTA('footer-cta')"
        >
          Umów wizytę
        </a>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5">
    <div class="container mx-auto px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-brand-muted">
      <p>© {year} Razor Sznyt. Wszelkie prawa zastrzeżone.</p>
      <a
        href="/polityka-prywatnosci"
        class="hover:text-brand-gold transition-colors duration-300"
      >
        Polityka prywatności
      </a>
    </div>
  </div>

</footer>
