---
const services = [
  {
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z" /></svg>`,
    title: 'Strzyżenie',
    description: 'Klasyczne i nowoczesne cięcia dopasowane do kształtu Twojej twarzy i stylu życia. Fade, undercut, crop — robimy to z klasą.',
  },
  {
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>`,
    title: 'Broda',
    description: 'Stylizacja, przycinanie i pielęgnacja brody. Rozprawiamy się z chaosem i nadajemy Ci odpowiedni wygląd — od stubble po pełną brodę.',
  },
  {
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3c-1.5 3-3 4.5-3 7a3 3 0 006 0c0-2.5-1.5-4-3-7zm0 0v18M9 21h6M7 10c-1.5.5-3 2-3 4h16c0-2-1.5-3.5-3-4" /></svg>`,
    title: 'Woskowanie & Relax',
    description: 'Woskowanie twarzy i uszu oraz waporyzacja na gorąco — skóra odświeżona, pory oczyszczone, a Ty wychodzisz jak nowy człowiek.',
  },
  {
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
    title: 'Cięcia dla dzieci',
    description: 'Przyjazna atmosfera i cierpliwość to nasz standard. Przychodź z synem — zadbamy o niego równie dobrze jak o Ciebie.',
  },
  {
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>`,
    title: 'Kompleksowe pakiety',
    description: 'Strzyżenie + broda w jednej wizycie. Wychodź gotowy od stóp do głów, bez chodzenia po mieście.',
  },
  {
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
    title: 'Rezerwacja online',
    description: 'Żadnego czekania, żadnego dzwonienia. Wybierz termin przez Booksy i przychodź na gotowe.',
  },
];
---

<section id="uslugi" class="section-padding bg-brand-surface">
  <div class="container mx-auto px-6 lg:px-8">

    <!-- Header -->
    <div class="max-w-2xl mb-14 lg:mb-20">
      <div class="flex items-center gap-3 mb-6">
        <span class="block w-8 h-px bg-brand-gold" aria-hidden="true"></span>
        <span class="text-brand-gold text-xs tracking-[0.4em] uppercase font-medium">Usługi</span>
      </div>
      <h2 class="font-heading text-4xl sm:text-5xl font-bold leading-tight">
        Co dla Ciebie<br />
        <span class="text-gradient">robimy.</span>
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-white/5">
      {services.map((service, i) => (
        <div class="group bg-brand-surface p-8 lg:p-10 transition-all duration-300 hover:bg-brand-surface-2 flex flex-col gap-4">
          <div class="w-10 h-10 text-brand-gold transition-transform duration-300 group-hover:scale-110" set:html={service.icon} />
          <h3 class="font-heading text-xl font-semibold text-brand-text">{service.title}</h3>
          <p class="text-brand-muted text-sm leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
