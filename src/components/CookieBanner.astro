---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-50 hidden border-t border-white/10 bg-brand-surface/95 backdrop-blur-lg"
  role="dialog"
  aria-label="Zgoda na pliki cookies"
>
  <div class="container mx-auto px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-brand-muted text-sm leading-relaxed text-center sm:text-left">
      Używamy plików cookies Google Analytics do analizy ruchu na stronie — wyłącznie za Twoją zgodą.
      <a
        href={`${base}/polityka-prywatnosci`}
        class="text-brand-gold hover:text-brand-gold-light underline underline-offset-2 ml-1 whitespace-nowrap"
      >
        Polityka prywatności
      </a>
    </p>
    <div class="flex items-center gap-3 shrink-0">
      <button
        id="cookie-reject"
        class="px-4 py-2 text-xs tracking-widest uppercase font-medium text-brand-muted hover:text-brand-text border border-white/20 hover:border-white/40 transition-colors duration-300"
      >
        Odrzuć
      </button>
      <button
        id="cookie-accept"
        class="px-5 py-2 text-xs tracking-widest uppercase font-semibold bg-brand-gold text-brand-black hover:bg-brand-gold-light transition-colors duration-300"
      >
        Akceptuję
      </button>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner')!;
  const acceptBtn = document.getElementById('cookie-accept')!;
  const rejectBtn = document.getElementById('cookie-reject')!;

  function getCookie(name: string): string | null {
    const match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
    return match ? decodeURIComponent(match[1]) : null;
  }

  function setCookie(name: string, value: string, days: number) {
    const expires = new Date(Date.now() + days * 864e5).toUTCString();
    document.cookie = `${name}=${encodeURIComponent(value)}; expires=${expires}; path=/; SameSite=Lax`;
  }

  if (!getCookie('cookie-consent')) {
    banner.classList.remove('hidden');
  }

  acceptBtn.addEventListener('click', () => {
    setCookie('cookie-consent', 'accepted', 365);
    banner.classList.add('hidden');
    if (typeof window.grantAnalyticsConsent === 'function') {
      window.grantAnalyticsConsent();
    }
  });

  rejectBtn.addEventListener('click', () => {
    setCookie('cookie-consent', 'rejected', 365);
    banner.classList.add('hidden');
  });
</script>
